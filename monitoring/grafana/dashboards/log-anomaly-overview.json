          "refId": "A"
        },
        {
          "expr": "sum by (endpoint) (rate(inference_latency_seconds_sum[5m])) / sum by (endpoint) (rate(inference_latency_seconds_count[5m]))",
          "legendFormat": "avg {{endpoint}}",
          "refId": "B"
        }
      ],
      "title": "Inference Latency",
      "type": "timeseries"
